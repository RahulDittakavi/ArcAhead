// ArcAhead data model. Arc `status` is DERIVED at request time from the user's
// currentEp vs start/end — it is intentionally NOT stored here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Series {
  id         String      @id
  title      String
  episodes   Int
  year       Int
  tracked    Int
  score      Int
  hue        Int
  tagline    String
  tag        String
  arcs       Arc[]
  characters Character[]
  reactions  Reaction[]
}

model Arc {
  id       String  @id
  seriesId String
  series   Series  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  name     String
  island   String
  saga     String
  start    Int
  end      Int
  rating   Float
  summary  String // spoiler-SAFE one-liner
  moments  String[] // spoiler-safe beats; withheld for future arcs
  watch    String
  future   Boolean  @default(false) // hard-fog flag relative to the build baseline
  banner   String? // IMAGES registry key

  @@index([seriesId, start])
}

model Character {
  id            String       @id
  seriesId      String
  series        Series       @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  name          String
  epithet       String?
  img           String? // IMAGES registry key
  crew          Boolean      @default(false)
  bounty        String?
  epaffirst     Int
  hue           Int
  role          String
  affil         String
  overview      String
  affiliations  String[]
  appearances   String[]
  relationships String[]
  locked        LockedFact[]

  @@index([seriesId, epaffirst])
}

model LockedFact {
  id          Int       @id @default(autoincrement())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  title       String
  unlockEp    Int
  hint        String

  @@index([characterId])
}

model Reaction {
  id       Int    @id @default(autoincrement())
  seriesId String
  series   Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user     String
  arc      String // arc display name as authored (spoiler-free by construction)
  text     String
  hype     Int
  ago      String
}

model User {
  id        String @id @default(cuid())
  email     String @unique
  currentEp Int    @default(381)
}
