{
  "name": "arcahead",
  "private": true,
  "version": "0.1.0",
  "description": "ArcAhead — spoiler-free One Piece companion (monorepo)",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "build:shared": "npm run build --workspace shared",
    "db:generate": "npm run prisma:generate --workspace server",
    "db:migrate": "npm run prisma:migrate --workspace server",
    "db:seed": "npm run seed --workspace server",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "setup": "npm install && npm run build:shared && npm run db:up && npm run db:migrate && npm run db:seed"
  }
}
